{
  "name": "langgraph-airline-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx --tsconfig tsconfig.cli.json src/main.ts",
    "dev": "next dev -p 3040",
    "dev:3000": "next dev -p 3000",
    "build": "next build",
    "start:web": "next start -p 3040",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.cli.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx --tsconfig tsconfig.cli.json src/regression/runner.ts"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.0.0",
    "@langchain/core": "^1.0.1",
    "@langchain/langgraph": "^1.0.1",
